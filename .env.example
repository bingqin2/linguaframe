COMPOSE_PROJECT_NAME=linguaframe

LINGUAFRAME_BACKEND_PORT=8080
LINGUAFRAME_FRONTEND_PORT=5173
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=100MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=100MB
LINGUAFRAME_MEDIA_MAX_FILE_SIZE_MB=100
LINGUAFRAME_MEDIA_MAX_DURATION_SECONDS=300
LINGUAFRAME_DEMO_ACCESS_TOKEN=
LINGUAFRAME_DEMO_ACCESS_HEADER_NAME=X-LinguaFrame-Demo-Token
LINGUAFRAME_DEMO_OWNER_ID=demo-owner
LINGUAFRAME_AUTH_ENABLED=false
LINGUAFRAME_AUTH_USERNAME=owner
LINGUAFRAME_AUTH_PASSWORD=
LINGUAFRAME_AUTH_JWT_SECRET=
LINGUAFRAME_AUTH_TOKEN_TTL_MINUTES=60
LINGUAFRAME_AUTH_ISSUER=linguaframe-local
LINGUAFRAME_OWNER_QUOTA_ENABLED=false
LINGUAFRAME_OWNER_QUOTA_MAX_ACTIVE_JOBS=0
LINGUAFRAME_OWNER_QUOTA_MAX_QUEUED_JOBS=0
LINGUAFRAME_OWNER_QUOTA_DAILY_BUDGET_GUARD_ENABLED=false
LINGUAFRAME_OWNER_QUOTA_MAX_DAILY_COST_USD=0
LINGUAFRAME_RATE_LIMIT_ENABLED=false
LINGUAFRAME_RATE_LIMIT_UPLOAD_MAX_REQUESTS=20
LINGUAFRAME_RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60
LINGUAFRAME_RATE_LIMIT_FAIL_OPEN=true
LINGUAFRAME_JOB_STATUS_CACHE_ENABLED=true
LINGUAFRAME_JOB_STATUS_CACHE_TTL_SECONDS=30
LINGUAFRAME_RETENTION_ENABLED=false
LINGUAFRAME_RETENTION_DRY_RUN=true
LINGUAFRAME_RETENTION_COMPLETED_JOB_TTL_DAYS=7
LINGUAFRAME_RETENTION_FAILED_JOB_TTL_DAYS=3
LINGUAFRAME_RETENTION_CANCELLED_JOB_TTL_DAYS=3
LINGUAFRAME_RETENTION_CLEANUP_BATCH_SIZE=25
LINGUAFRAME_RETENTION_SCHEDULER_ENABLED=false
LINGUAFRAME_RETENTION_SCHEDULER_INTERVAL_MS=3600000
LINGUAFRAME_COST_ENABLED=true
LINGUAFRAME_COST_TRANSCRIPTION_USD_PER_MINUTE=0
LINGUAFRAME_COST_TRANSLATION_INPUT_USD_PER_1M_TOKENS=0
LINGUAFRAME_COST_TRANSLATION_OUTPUT_USD_PER_1M_TOKENS=0
LINGUAFRAME_COST_TTS_USD_PER_1M_CHARS=0
LINGUAFRAME_COST_BUDGET_GUARD_ENABLED=false
LINGUAFRAME_COST_MAX_JOB_COST_USD=0
LINGUAFRAME_COST_DAILY_BUDGET_GUARD_ENABLED=false
LINGUAFRAME_COST_MAX_DAILY_COST_USD=0
LINGUAFRAME_COST_BUDGET_IDENTITY=demo-owner
LINGUAFRAME_WORKER_DISPATCH_ENABLED=true
LINGUAFRAME_WORKER_DISPATCH_BATCH_SIZE=10
LINGUAFRAME_WORKER_DISPATCH_INTERVAL_MS=5000
LINGUAFRAME_WORKER_MAX_RETRIES=2
LINGUAFRAME_WORKER_EXECUTION_ENABLED=true
LINGUAFRAME_WORKER_ROLE=COMBINED
LINGUAFRAME_WORKER_SMOKE_STAGE_DURATION_MS=0
LINGUAFRAME_WORKER_SMOKE_STAGE_FAILURE_ENABLED=false
LINGUAFRAME_FFMPEG_BINARY_PATH=ffmpeg
LINGUAFRAME_FFMPEG_AUDIO_ENABLED=true
LINGUAFRAME_FFMPEG_AUDIO_TIMEOUT_SECONDS=120
LINGUAFRAME_FFMPEG_BURN_IN_ENABLED=true
LINGUAFRAME_FFMPEG_BURN_IN_TIMEOUT_SECONDS=180
LINGUAFRAME_FFMPEG_WORK_DIR=/tmp/linguaframe-media
LINGUAFRAME_TRANSCRIPTION_ENABLED=true
LINGUAFRAME_TRANSCRIPTION_PROVIDER=demo
LINGUAFRAME_TRANSLATION_ENABLED=true
LINGUAFRAME_TRANSLATION_PROVIDER=demo
LINGUAFRAME_TTS_ENABLED=false
LINGUAFRAME_TTS_PROVIDER=demo
LINGUAFRAME_EVALUATION_ENABLED=false
LINGUAFRAME_EVALUATION_PROVIDER=demo
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=
OPENAI_TRANSCRIPTION_TIMEOUT_SECONDS=120
OPENAI_TRANSLATION_MODEL=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_TRANSLATION_TIMEOUT_SECONDS=60
OPENAI_TTS_MODEL=
OPENAI_TTS_VOICE=
OPENAI_TTS_TIMEOUT_SECONDS=120
OPENAI_EVALUATION_MODEL=
OPENAI_EVALUATION_TIMEOUT_SECONDS=60
LINGUAFRAME_OPENAI_CONNECTIVITY_CHECK_ENABLED=false
LINGUAFRAME_OPENAI_CONNECTIVITY_MODEL=
LINGUAFRAME_OPENAI_CONNECTIVITY_TIMEOUT_SECONDS=5

MYSQL_DATABASE=linguaframe
MYSQL_USER=linguaframe
MYSQL_PASSWORD=linguaframe_dev_password
MYSQL_ROOT_PASSWORD=linguaframe_root_password
MYSQL_PORT=3306

REDIS_PORT=6379

RABBITMQ_USER=linguaframe
RABBITMQ_PASSWORD=linguaframe_dev_password
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_JOB_EXCHANGE=linguaframe.jobs
RABBITMQ_JOB_QUEUE=linguaframe.localization.jobs
RABBITMQ_JOB_ROUTING_KEY=localization.queued
RABBITMQ_FFMPEG_JOB_QUEUE=linguaframe.localization.jobs
RABBITMQ_OPENAI_JOB_QUEUE=linguaframe.localization.openai.jobs
RABBITMQ_FFMPEG_JOB_ROUTING_KEY=localization.queued
RABBITMQ_OPENAI_JOB_ROUTING_KEY=localization.openai
RABBITMQ_LISTENER_QUEUE=linguaframe.localization.jobs

MINIO_ROOT_USER=linguaframe
MINIO_ROOT_PASSWORD=linguaframe_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=linguaframe-artifacts
